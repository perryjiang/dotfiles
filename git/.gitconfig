[alias]
	br = branch
	ci = commit
	co = checkout
	d = diff
	l = log --graph --oneline --all --simplify-by-decoration --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)'
	st = status
[apply]
	whitespace = fix
[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green
[color "diff"]
	frag = magenta bold
	meta = yellow bold
	new = green bold
	old = red bold
	whitespace = red reverse
[color "status"]
	added = yellow
	changed = green
	untracked = cyan
[core]
	autocrlf = input
	excludesFile = ~/.gitignore_global
	untrackedCache = true
[credential]
	helper = osxkeychain
[diff]
	algorithm = histogram
	context = 8
	mnemonicPrefix = true
	renames = copies
[fetch]
	prune = true
[merge]
	conflictStyle = diff3
	tool = vimdiff
[pull]
	ff = only
[user]
	email = me@perryjiang.com
	name = Perry Jiang
