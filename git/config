[alias]
	a = add
	au = add --update
	amend = commit --amend --no-edit
	br = branch
	brd = branch --delete
	caa = commit --all --amend --no-edit
	ci = commit
	cl = clone
	co = checkout
	cob = checkout -b
	d = diff
	dc = diff --cached
	ds = diff --stat
	fu = commit --fixup
	fuh = commit --fixup HEAD
	rb = rebase
	rba = rebase --abort
	rbc = rebase --continue
	rbi = rebase --interactive
	rmb = !git branch --merged master | grep -v '^\\* master' | xargs -n 1 --no-run-if-empty git branch -d
	sh = show
	shs = show --stat
	sq = commit --squash
	st = status
        # TODO: https://stackoverflow.com/questions/46695859/should-i-use-sh-c-or-f-f-in-git-alias-scripts
	sync = !sh -c 'git checkout --quiet --detach && git fetch origin master:master && git checkout --quiet -'
	wow = log --graph --oneline --all --simplify-by-decoration --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)'
[apply]
	whitespace = fix
[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green
[color "diff"]
	frag = magenta bold
	meta = yellow bold
	new = green bold
	old = red bold
	whitespace = red reverse
[color "status"]
	added = yellow
	changed = green
	untracked = cyan
[core]
	autocrlf = input
	excludesFile = ~/dotfiles/git/gitignore_global
	pager = delta
	untrackedCache = true
[credential]
	helper = osxkeychain
[delta]
	features = side-by-side
	syntax-theme = Nord
[diff]
	algorithm = histogram
	colorMoved = default
	mnemonicPrefix = true
	renames = copies
[fetch]
	prune = true
[interactive]
	diffFilter = delta --color-only
[merge]
	conflictStyle = diff3
	tool = vimdiff
[pull]
	ff = only
[rebase]
	autoSquash = true
[rerere]
	autoUpdate = true
	enabled = true
[user]
	email = me@perryjiang.com
	name = Perry Jiang
