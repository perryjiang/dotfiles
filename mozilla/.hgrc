[alias]
wip = log --graph --rev=wip --template=wip
smart-annotate = annotate -w --skip ignored_changesets

[bugzilla]
username = perry@mozilla.com

[color]
wip.bookmarks = yellow underline
wip.branch = yellow
wip.draft = green
wip.here = red
wip.obsolete = none
wip.public = blue
wip.tags = yellow
wip.user = magenta

[diff]
git = true
showfunc = true
unified = 8

[experimental]
graphshorten = true

[extdata]
get_ignored_changesets = shell:cat `hg root`/.hg-annotate-ignore-revs 2> /dev/null || true

[extensions]
absorb =
blackbox =
clang-format = $HOME/.mozbuild/version-control-tools/hgext/clang-format
evolve = $HOME/.mozbuild/evolve/hgext3rd/evolve
firefoxtree = $HOME/.mozbuild/version-control-tools/hgext/firefoxtree
format-source = $HOME/.mozbuild/version-control-tools/hgext/format-source
fsmonitor =
histedit =
purge =
push-to-try = $HOME/.mozbuild/version-control-tools/hgext/push-to-try
rebase =
share =
shelve =
strip =

[mozilla]
ircnick = perry

[pager]
# Commands to disable the pager for
ignore = version, help, update

[revsetalias]
wip = (parents(not public()) or not public() or . or (head() and branch(default))) and (not obsolete() or orphan()^) and not closed() and not (fxheads() - date(-90))
ignored_changesets = desc("ignore-this-changeset") or extdata(get_ignored_changesets)

[templates]
wip = '{label("wip.branch", if(branches,"{branches} "))}{label(ifeq(graphnode,"x","wip.obsolete","wip.{phase}"),"{rev}:{node|short}")}{label("wip.user", " {author|user}")}{label("wip.tags", if(tags," {tags}"))}{label("wip.tags", if(fxheads," {fxheads}"))}{if(bookmarks," ")}{label("wip.bookmarks", if(bookmarks,bookmarks))}{label(ifcontains(rev, revset("parents()"), "wip.here"), " {desc|firstline}")}'

[ui]
ignore = $DOTFILES/mozilla/.hgignore_global
interface = curses
merge = vimdiff
tweakdefaults = true
username = Perry Jiang <perry@mozilla.com>
